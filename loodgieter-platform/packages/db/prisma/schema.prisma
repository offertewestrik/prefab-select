// Loodgieterplatform.nl — datamodel (zie docs/03-datamodel.md)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────── Enums ─────────────────────────────
enum UserRole {
  HOMEOWNER
  INSTALLER
  ADMIN
}

enum CompanyRole {
  OWNER
  MANAGER
  STAFF
}

enum CompanyStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum LeadStatus {
  NEW
  MATCHING
  DISTRIBUTED
  PARTIALLY_SOLD
  SOLD_OUT
  CLOSED
  EXPIRED
  SPAM
}

enum MatchStatus {
  OFFERED
  VIEWED
  PURCHASED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum Urgency {
  SPOED
  BINNEN_WEEK
  FLEXIBEL
}

enum Daypart {
  OCHTEND
  MIDDAG
  AVOND
  MAAKT_NIET_UIT
}

enum AppointmentStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum ReviewSource {
  PLATFORM
  IMPORTED
  MANUAL
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum CreditTxnType {
  TOPUP
  SPEND
  REFUND
  BONUS
  ADJUSTMENT
}

enum PublishState {
  ACTIVE
  HIDDEN
}

enum AttachmentKind {
  PHOTO
  DOCUMENT
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

// ──────────────────────── Identity & Access ───────────────────────
model User {
  id            String    @id @default(cuid())
  role          UserRole  @default(HOMEOWNER)
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships CompanyMember[]
  leads       LeadRequest[]
  accounts    Account[]
  sessions    Session[]
}

// Auth.js modellen
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InstallerCompany {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  kvk           String?       @unique
  vatNumber     String?
  email         String
  phone         String
  website       String?
  logoUrl       String?
  coverImageUrl String?
  shortDescription String?
  description   String?       @db.Text
  specialties   String[]
  foundedYear   Int?
  yearsExperience Int?
  employees     Int?
  openingHours  Json?
  emergencyService Boolean    @default(false)
  warrantyText  String?       @db.Text
  contactName   String?
  street        String?
  postcode      String?
  city          String?
  province      String?
  status        CompanyStatus @default(PENDING_REVIEW)
  publicVisible Boolean       @default(true)
  ratingAvg     Float         @default(0)
  ratingCount   Int           @default(0)
  creditBalance Int           @default(0)
  autoBuy       Boolean       @default(false)
  stripeCustomerId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  members        CompanyMember[]
  services       CompanyService[]
  coverage       CompanyCoverage[]
  certifications Certification[]
  photos         CompanyPhoto[]
  matches        LeadMatch[]
  purchases      LeadPurchase[]
  appointments   Appointment[]
  reviews        Review[]
  creditTxns     CreditTransaction[]
  invoices       Invoice[]
  quotes         Quote[]
  payments       Payment[]
  subscription   Subscription?

  @@index([status])
}

model CompanyMember {
  id        String      @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRole @default(STAFF)
  company   InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model Certification {
  id         String    @id @default(cuid())
  companyId  String
  type       String
  number     String?
  validUntil DateTime?
  fileUrl    String?
  company    InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// Portfolio-foto's van een bedrijf (publiek profiel).
model CompanyPhoto {
  id        String           @id @default(cuid())
  companyId String
  url       String
  caption   String?
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  company   InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ───────────────────────────── Geo ────────────────────────────────
model Province {
  id            String         @id @default(cuid())
  name          String         @unique
  slug          String         @unique
  municipalities Municipality[]
}

model Municipality {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  provinceId String
  cbsCode    String?      @unique
  population Int?
  lat        Float
  lng        Float
  publish       PublishState @default(ACTIVE)
  contentBlocks Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  province      Province     @relation(fields: [provinceId], references: [id])

  places     Place[]
  coverage   CompanyCoverage[]
  leads      LeadRequest[]
  landing    LandingContent[]

  @@index([provinceId])
}

model Place {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  municipalityId String
  lat            Float
  lng            Float
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@index([municipalityId])
}

model CompanyCoverage {
  id             String           @id @default(cuid())
  companyId      String
  municipalityId String?
  centerLat      Float?
  centerLng      Float?
  radiusKm       Int?
  company        InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  municipality   Municipality?    @relation(fields: [municipalityId], references: [id])

  @@index([companyId])
  @@index([municipalityId])
}

// ─────────────────────────── Catalog ──────────────────────────────
model ServiceCategory {
  id       String            @id @default(cuid())
  slug     String            @unique
  name     String
  parentId String?
  order    Int               @default(0)
  icon     String?
  parent   ServiceCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ServiceCategory[] @relation("CategoryTree")
  services Service[]
}

model Service {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  categoryId       String
  shortDescription String
  longDescription  String          @db.Text
  heroImageUrl     String?
  icon             String?
  priceFrom        Int?
  priceTo          Int?
  priceUnit        String?
  avgDurationHrs   Float?
  seoTitle         String?
  metaDescription  String?
  keywords         String[]
  contentBlocks    Json?           // flexibele blokken (zie packages/content)
  publish          PublishState    @default(ACTIVE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  category         ServiceCategory @relation(fields: [categoryId], references: [id])

  brands       ServiceBrand[]
  brandPages   ServiceBrandPage[]
  faqs         Faq[]
  relatedFrom  ServiceRelation[] @relation("relFrom")
  relatedTo    ServiceRelation[] @relation("relTo")
  leads        LeadRequest[]
  landing      LandingContent[]
  companies    CompanyService[]

  @@index([categoryId])
}

model Brand {
  id            String             @id @default(cuid())
  slug          String             @unique
  name          String
  logoUrl       String?
  type          String?
  description   String?            @db.Text
  contentBlocks Json?
  seoTitle      String?
  metaDescription String?
  services      ServiceBrand[]
  brandPages    ServiceBrandPage[]
  leads         LeadRequest[]
}

// Dienst × merk-paginacontent (bv. "CV-ketel vervangen — Intergas").
model ServiceBrandPage {
  id              String   @id @default(cuid())
  serviceId       String
  brandId         String
  introHtml       String?  @db.Text
  contentBlocks   Json?
  seoTitle        String?
  metaDescription String?
  noindex         Boolean  @default(false)
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([serviceId, brandId])
}

model ServiceBrand {
  serviceId String
  brandId   String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  brand     Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([serviceId, brandId])
}

model ServiceRelation {
  fromId String
  toId   String
  from   Service @relation("relFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Service @relation("relTo", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
}

model CompanyService {
  companyId String
  serviceId String
  company   InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([companyId, serviceId])
  @@index([serviceId])
}

// ───────────────────────── SEO / Content ──────────────────────────
model LandingContent {
  id              String       @id @default(cuid())
  serviceId       String
  municipalityId  String
  introHtml       String?      @db.Text
  contentBlocks   Json?
  customFaqs      Json?
  seoTitle        String?
  metaDescription String?
  noindex         Boolean      @default(false)
  service         Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  municipality    Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@unique([serviceId, municipalityId])
}

model Faq {
  id        String   @id @default(cuid())
  scope     String   // SERVICE | CITY | GLOBAL | SERVICE_CITY
  serviceId String?
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model SeoMeta {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String?
  description String?
  h1          String?
  h2          Json?    // optionele lijst van H2-koppen
  ogImageUrl  String?
  canonical   String?
  noindex     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model Redirect {
  id        String   @id @default(cuid())
  from      String   @unique
  to        String
  permanent Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Article {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String
  excerpt         String?
  content         String           @db.Text
  coverImageUrl   String?
  categoryId      String?
  authorId        String?
  status          ArticleStatus    @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  readingTime     Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        ArticleCategory? @relation(fields: [categoryId], references: [id])
  author          Author?          @relation(fields: [authorId], references: [id])
  tags            ArticleTag[]

  @@index([categoryId])
  @@index([status])
}

model ArticleCategory {
  id       String            @id @default(cuid())
  slug     String            @unique
  name     String
  parentId String?
  parent   ArticleCategory?  @relation("ArticleCatTree", fields: [parentId], references: [id])
  children ArticleCategory[] @relation("ArticleCatTree")
  articles Article[]
}

model Author {
  id        String    @id @default(cuid())
  userId    String?
  name      String
  slug      String    @unique
  bio       String?
  avatarUrl String?
  articles  Article[]
}

model Tag {
  id       String       @id @default(cuid())
  slug     String       @unique
  name     String
  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Page {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  blocks          Json
  status          PageStatus @default(DRAFT)
  seoTitle        String?
  metaDescription String?
  updatedAt       DateTime   @updatedAt
}

// ────────────────────── Marketplace / Leads ───────────────────────
model LeadRequest {
  id               String       @id @default(cuid())
  homeownerId      String?
  serviceId        String
  brandId          String?
  municipalityId   String
  postcode         String
  houseNumber      String?
  street           String?
  city             String
  lat              Float?
  lng              Float?
  urgency          Urgency
  description      String       @db.Text
  preferredDate    DateTime?
  preferredDaypart Daypart      @default(MAAKT_NIET_UIT)
  budgetIndication String?
  contactName      String
  contactEmail     String
  contactPhone     String
  status           LeadStatus   @default(NEW)
  priceCredits     Int
  maxBuyers        Int          @default(3)
  soldCount        Int          @default(0)
  source           String?
  utm              Json?
  spamScore        Float?
  ipHash           String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  homeowner    User?        @relation(fields: [homeownerId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])
  brand        Brand?       @relation(fields: [brandId], references: [id])
  municipality Municipality @relation(fields: [municipalityId], references: [id])
  attachments  LeadAttachment[]
  matches      LeadMatch[]
  appointments Appointment[]
  quotes       Quote[]

  @@index([serviceId])
  @@index([municipalityId])
  @@index([status])
}

model LeadAttachment {
  id         String         @id @default(cuid())
  leadId     String
  url        String
  kind       AttachmentKind @default(PHOTO)
  name       String?
  aiAnalysis Json?
  lead       LeadRequest    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Quote {
  id            String           @id @default(cuid())
  companyId     String
  leadId        String?
  number        String           @unique
  title         String?
  introText     String?          @db.Text
  lineItems     Json             // [{ description, qty, unitPriceCents }]
  subtotalCents Int              @default(0)
  vatRate       Int              @default(21) // btw-percentage
  vatCents      Int              @default(0)
  totalCents    Int              @default(0)
  terms         String?          @db.Text
  notes         String?          @db.Text
  status        QuoteStatus      @default(DRAFT)
  validUntil    DateTime?
  pdfUrl        String?
  accessToken   String?          @unique // beveiligde klant-link
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  company       InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead          LeadRequest?     @relation(fields: [leadId], references: [id])

  @@index([companyId])
  @@index([leadId])
}

model LeadMatch {
  id           String           @id @default(cuid())
  leadId       String
  companyId    String
  status       MatchStatus      @default(OFFERED)
  priceCredits Int
  offeredAt    DateTime         @default(now())
  viewedAt     DateTime?
  purchasedAt  DateTime?
  lead         LeadRequest      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company      InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchase     LeadPurchase?

  @@unique([leadId, companyId])
  @@index([companyId, status])
}

model LeadPurchase {
  id           String           @id @default(cuid())
  leadMatchId  String           @unique
  companyId    String
  creditsSpent Int
  creditTxnId  String?
  createdAt    DateTime         @default(now())
  match        LeadMatch        @relation(fields: [leadMatchId], references: [id], onDelete: Cascade)
  company      InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Appointment {
  id          String            @id @default(cuid())
  leadId      String
  companyId   String
  scheduledAt DateTime
  status      AppointmentStatus @default(PLANNED)
  notes       String?
  createdAt   DateTime          @default(now())
  lead        LeadRequest       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company     InstallerCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ───────────────────────────── Billing ────────────────────────────
model CreditTransaction {
  id           String           @id @default(cuid())
  companyId    String
  type         CreditTxnType
  amount       Int
  balanceAfter Int
  reference    String?
  createdAt    DateTime         @default(now())
  company      InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// Admin-beheerbare credit-pakketten.
model CreditPackage {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  credits    Int
  priceCents Int
  currency   String    @default("eur")
  active     Boolean   @default(true)
  order      Int       @default(0)
  payments   Payment[]
}

// Een betaling/checkout-sessie voor credits (tevens de StripeCheckoutSession-record).
model Payment {
  id                    String           @id @default(cuid())
  companyId             String
  packageId             String?
  credits               Int
  amountCents           Int
  currency              String           @default("eur")
  status                PaymentStatus    @default(PENDING)
  stripeSessionId       String?          @unique
  stripePaymentIntentId String?
  creditTxnId           String?
  createdAt             DateTime         @default(now())
  paidAt                DateTime?
  company               InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  package               CreditPackage?   @relation(fields: [packageId], references: [id])

  @@index([companyId])
  @@index([status])
}

// Idempotentie voor Stripe-webhooks: elk event-id wordt maar één keer verwerkt.
model StripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}

model Invoice {
  id              String           @id @default(cuid())
  companyId       String
  number          String           @unique
  amountCents     Int
  vatCents        Int
  status          String
  pdfUrl          String?
  stripeInvoiceId String?
  createdAt       DateTime         @default(now())
  company         InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Plan {
  id                String         @id @default(cuid())
  slug              String         @unique
  name              String
  priceMonthlyCents Int
  features          Json
  includedCredits   Int            @default(0)
  subscriptions     Subscription[]
}

model Subscription {
  id                   String           @id @default(cuid())
  companyId            String           @unique
  planId               String
  stripeSubscriptionId String?
  status               String
  currentPeriodEnd     DateTime?
  company              InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan                 Plan             @relation(fields: [planId], references: [id])
}

// ───────────────────────────── Reviews ────────────────────────────
model Review {
  id           String           @id @default(cuid())
  companyId    String
  homeownerId  String?
  leadId       String?
  quoteId      String?
  rating       Int
  title        String?
  body         String           @db.Text
  serviceSlug  String?
  cityName     String?
  customerName String
  showName     Boolean          @default(true)
  status       ReviewStatus     @default(PENDING)
  source       ReviewSource     @default(PLATFORM)
  reply        String?
  verified     Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      InstallerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

model ReviewInvite {
  id            String    @id @default(cuid())
  companyId     String
  leadId        String?
  quoteId       String?   @unique
  token         String    @unique
  customerEmail String?
  sentAt        DateTime?
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
}

// ─────────────────────────── Cross-cutting ────────────────────────
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model EmailLog {
  id         String   @id @default(cuid())
  to         String
  template   String
  status     String
  providerId String?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  diff       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
