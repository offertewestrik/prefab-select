# ─── Loodgieterplatform.nl — omgevingsvariabelen ───────────────────────────
# Kopieer dit bestand naar .env.local en vul de waarden in.

# ── E-mailmeldingen (Resend) ──
# Maak gratis een account op https://resend.com en plak hier je API key.
RESEND_API_KEY=
# Afzender. Pas aan zodra je domein loodgieterplatform.nl is geverifieerd in Resend.
# Tot die tijd werkt onboarding@resend.dev als test-afzender.
RESEND_SENDER_EMAIL=onboarding@resend.dev
# Naar welk adres komen nieuwe aanvragen binnen?
CONTACT_RECEIVER_EMAIL=info@loodgieterplatform.nl

# ── Opslag van leads (Firebase Firestore) ──
# Project-ID van je Firebase-project. Leeg laten = leads worden alleen gemaild
# (de site blijft gewoon werken).
FIREBASE_PROJECT_ID=
# Pad naar de service-account sleutel (JSON) of laat Cloud Run/Vercel dit zelf regelen.
GOOGLE_APPLICATION_CREDENTIALS=
# Optioneel: naam van de Firestore-database als die niet '(default)' heet.
FIRESTORE_DATABASE_ID=

# ── Dashboard-beveiliging ──
# Wachtwoord om in te loggen op /dashboard. KIES EEN EIGEN STERK WACHTWOORD.
DASHBOARD_PASSWORD=verander-dit-wachtwoord

# ── Optioneel: doorzetten naar Make.com / Zapier ──
MAKE_WEBHOOK_URL=
