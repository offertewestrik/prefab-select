# ─── Loodgieterplatform.nl — omgevingsvariabelen ───────────────────────────
# Kopieer naar .env (root, voor Prisma) en apps/web/.env.local (voor de app).

# ── Database (Supabase Postgres) ──
# Pooled connection (PgBouncer, poort 6543) voor de app:
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# Directe connection (poort 5432) voor migraties:
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ── Auth.js (NextAuth v5) ──
NEXTAUTH_SECRET=                 # genereer met: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── E-mail (Resend) ──
RESEND_API_KEY=
RESEND_SENDER_EMAIL=onboarding@resend.dev
CONTACT_RECEIVER_EMAIL=info@loodgieterplatform.nl

# ── Betalingen (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Uploads (UploadThing) ──
UPLOADTHING_TOKEN=

# ── Kaarten ──
NEXT_PUBLIC_MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# ── Anti-spam (Cloudflare Turnstile) ──
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI (fase later) ──
OPENAI_API_KEY=

# Photo Analyzer (Vision)
PHOTO_AI_PROVIDER=mock
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_VISION_TIMEOUT_MS=30000
