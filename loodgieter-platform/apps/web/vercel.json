{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @repo/db generate && next build",
  "crons": [
    {
      "path": "/api/cron/expire-quotes",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/ai-daily-report",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/reap-jobs",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/cleanup-uploads",
      "schedule": "0 4 * * *"
    }
  ]
}
