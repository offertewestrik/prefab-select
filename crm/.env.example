# ============================================================================
# Prefab Select CRM — omgevingsvariabelen
# ----------------------------------------------------------------------------
# Het prototype draait VOLLEDIG op dummy data; geen van onderstaande keys is
# nodig om te starten. Vul ze pas in wanneer we per stap de echte koppeling
# activeren (zie src/lib/integrations/*).
# ============================================================================

# --- Supabase (database, auth, storage) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (Postgres connection string van Supabase) -----------------------
DATABASE_URL=

# --- Resend (offertes mailen) -----------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=offerte@prefabselect.nl

# --- Google (Calendar + Analytics Data API) ---------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
GA4_PROPERTY_ID=

# --- Meta Marketing API -----------------------------------------------------
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# --- Feature flag: zet op "true" om mocks te vervangen door echte calls -----
USE_REAL_INTEGRATIONS=false
