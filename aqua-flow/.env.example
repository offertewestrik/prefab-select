# Aqua Flow Water Services — environment configuration
# Copy to .env.local and fill in the values you need.

# Public contact details (rendered in CTAs across the site)
NEXT_PUBLIC_PHONE_NUMBER="+971500000000"
NEXT_PUBLIC_WHATSAPP_NUMBER="971500000000"
NEXT_PUBLIC_CONTACT_EMAIL="hello@aquaflow.ae"

# Google Maps embed key (optional — used by the contact map)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Hero media. Defaults point at the AI-generated clip on Higgsfield's CDN.
# To self-host, download them into /public and set these to local paths.
NEXT_PUBLIC_HERO_VIDEO_URL=""
NEXT_PUBLIC_HERO_POSTER_URL=""
