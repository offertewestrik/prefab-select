# Al Naqaa (النقاء) Drinking Water — environment configuration
# Copy to .env.local and fill in the values you need.

# Public contact details (rendered in CTAs across the site)
NEXT_PUBLIC_PHONE_NUMBER="+971500000000"
NEXT_PUBLIC_WHATSAPP_NUMBER="971500000000"
NEXT_PUBLIC_CONTACT_EMAIL="hello@alnaqaa.ae"

# Google Maps embed key (optional — used by the contact map)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Media. By default the site serves local files from /public (see public/MEDIA.md).
# Set these to any public URL (your own CDN/S3) to override without self-hosting.
NEXT_PUBLIC_HERO_VIDEO_URL=""
NEXT_PUBLIC_HERO_POSTER_URL=""
NEXT_PUBLIC_PROCESS_VIDEO_URL=""
