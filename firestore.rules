rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Collection: Leads
    // Leads are only written by the server via the Admin SDK (which bypasses
    // these rules); clients never write leads directly.
    match /leads/{leadId} {
      allow create: if false;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == userId 
                            && request.resource.data.role == "user" // Users cannot self-promote
                            && request.resource.data.email == request.auth.token.email;
      allow delete: if isAdmin();
    }
    
    // Explicit Admin collection check
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false; // Only manageable via Google Cloud Console/Admin SDK
    }
  }
}
