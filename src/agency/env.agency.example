# =============================================================================
# Agency Command Center — integration environment variables
# -----------------------------------------------------------------------------
# Self-contained example for the dashboard at /agency. Copy the variables you
# need into your real .env (which is git-ignored). The root .env.example is left
# untouched on purpose — the dashboard keeps its own config file.
#
# (Named without a leading dot so it is tracked by git; .gitignore ignores
#  every .env* file. Rename to .env.agency when copying for local use.)
#
# IMPORTANT: Real secret keys must NEVER ship in client code. The VITE_* values
# are only used client-side to detect whether an integration is "connected"
# (feature flags). Keep the actual tokens server-side and call the external APIs
# from Cloud Functions / the Express server. See AGENCY_DASHBOARD.md.
# =============================================================================

# --- AI providers (server-side) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY is already present in the root .env.example and reused here.

# --- Google Analytics 4 (Data API, server-side via service account) ---
GA4_PROPERTY_ID=
# Auth uses GOOGLE_APPLICATION_CREDENTIALS from the root .env.example.

# --- Meta (Facebook/Instagram) Marketing API (server-side) ---
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# --- Google Ads API (server-side) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# --- GitHub (server-side) ---
GITHUB_TOKEN=

# --- Client-side feature flags (safe: presence only, no secrets) ---
# Set to any non-empty value to mark an integration as "connected" in the UI.
VITE_GITHUB_TOKEN=
VITE_META_ADS_ACCESS_TOKEN=
VITE_GA4_PROPERTY_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
