# Gemini API Key
GEMINI_API_KEY=

# Make.com Integration
MAKE_WEBHOOK_URL=

# Meta (Facebook) Pixel Configuration
VITE_META_PIXEL_ID=

# Resend Email Integration
RESEND_API_KEY=
RESEND_SENDER_EMAIL=onboarding@resend.dev
CONTACT_RECEIVER_EMAIL=offerte@prefabselect.nl

# Firebase Configuration
FIREBASE_PROJECT_ID=
# For Cloud Run, service accounts can be mounted via APPLICATION_DEFAULT_CREDENTIALS or by providing standard credentials
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# Agency Command Center (dashboard at /agency) integrations
# -----------------------------------------------------------------------------
# IMPORTANT: Real secret keys must NEVER ship in client code. The VITE_*
# variables below are only used client-side to detect whether an integration is
# "connected" (feature flags) — keep the actual tokens server-side and call the
# external APIs from Cloud Functions / the Express server. See README.md.
# =============================================================================

# --- AI providers (server-side) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY is already defined above and reused by the AI agents.

# --- Google Analytics 4 (Data API, server-side via service account) ---
GA4_PROPERTY_ID=
# Uses GOOGLE_APPLICATION_CREDENTIALS above for auth.

# --- Meta (Facebook/Instagram) Marketing API (server-side) ---
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# --- Google Ads API (server-side) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# --- GitHub (server-side) ---
GITHUB_TOKEN=

# --- Client-side feature flags (safe: presence only, no secrets) ---
# Set these to any non-empty value to mark an integration as "connected" in the UI.
VITE_GITHUB_TOKEN=
VITE_META_ADS_ACCESS_TOKEN=
VITE_GA4_PROPERTY_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
